# HTTP runtime mode is mandatory and must be exactly REPLAY or LIVE.
ARENA90_RUNTIME_MODE=

# LIVE must autostart and defaults to true. REPLAY defaults to false; set true
# for an always-ready fallback runtime. Invalid values fail closed.
ARENA90_AUTOSTART=

# Required strict manifest file for both modes. The manifest must match the
# selected Replay recording or Live fixture binding exactly.
ARENA90_MANIFEST_FILE=

# Required only for REPLAY. No LIVE fallback is attempted.
ARENA90_REPLAY_RECORDING_FILE=

# Required only for LIVE. File must contain only fixtureId, participant1Id,
# participant2Id, participant1IsHome, and startTime.
ARENA90_LIVE_FIXTURE_BINDING_FILE=
ARENA90_LIVE_DELAYED=

# HTTP defaults to loopback and port 3000. No wildcard CORS is enabled.
ARENA90_HTTP_HOST=127.0.0.1
ARENA90_HTTP_PORT=3000

# Required by lifecycle and HTTP acceptance runs. Stores one atomic JSON record
# per arena. Keep runtime data outside Git and preserve it across process restart.
ARENA90_PERSISTENCE_DIR=

# Optional ZeroClaw binary override for agent and HTTP Replay commands.
ZEROCLAW_BIN=zeroclaw

# Required by both `npm run smoke:zeroclaw` and
# `npm run smoke:lifecycle:replay`, plus the HTTP runtime/smoke.
ZEROCLAW_CONFIG_DIR=
# Use separate writable ZeroClaw state for concurrent Alpha/Beta invocations.
# If either value is omitted, the legacy shared ZEROCLAW_CONFIG_DIR is used.
ZEROCLAW_ALPHA_CONFIG_DIR=
ZEROCLAW_BETA_CONFIG_DIR=
ARENA90_AGENT_TIMEOUT_MS=30000

# Optional non-secret overall timeout for `npm run smoke:lifecycle:replay`.
# Defaults to 900000 milliseconds.
ARENA90_REPLAY_SMOKE_TIMEOUT_MS=900000

# Optional non-secret timeout for `npm run smoke:http:replay`.
ARENA90_HTTP_SMOKE_TIMEOUT_MS=900000

# Optional HTTP smoke gate. Defaults to PRODUCT_ACCEPTANCE. Set explicitly to
# CLEAN_SHOWCASE only for the stricter demo-readiness check; no downgrade occurs.
ARENA90_HTTP_SMOKE_MODE=PRODUCT_ACCEPTANCE

# Required for the TxLINE runtime client in LIVE mode. The connectivity smoke
# accepts these values from environment or the optional credential file below.
TXLINE_BASE_URL=
TXLINE_JWT=
TXLINE_API_TOKEN=

# Required for both the runtime client and `npm run smoke:txline`.
TXLINE_TIMEOUT_MS=
TXLINE_MAX_RESPONSE_BYTES=
TXLINE_MAX_SSE_EVENTS=

# Required separately for `npm run smoke:txline`.
TXLINE_FIXTURE_ID=

# Optional smoke-only path to JSON credentials outside Git. Only apiOrigin,
# jwt, and apiToken are read. Explicit environment values above take priority.
TXLINE_CREDENTIALS_FILE=
