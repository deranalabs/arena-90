# One locked Live arena. Keep the real credential file outside Git/releases.
ARENA90_RUNTIME_MODE=LIVE
ARENA90_AUTOSTART=true
ARENA90_MANIFEST_FILE=/etc/arena90/config/world-cup-third-place-v4-manifest.json
ARENA90_LIVE_FIXTURE_BINDING_FILE=/etc/arena90/config/world-cup-third-place-binding.json
ARENA90_LIVE_DELAYED=false

ARENA90_HTTP_HOST=127.0.0.1
ARENA90_HTTP_PORT=3100
ARENA90_PERSISTENCE_DIR=/var/lib/arena90/persistence

ZEROCLAW_BIN=/usr/local/bin/zeroclaw
ZEROCLAW_CONFIG_DIR=/etc/arena90/zeroclaw
ARENA90_AGENT_TIMEOUT_MS=30000

# Owner-only JSON file (0600), outside Git and immutable releases.
TXLINE_CREDENTIALS_FILE=/etc/arena90/secrets/txline-credentials.json
TXLINE_TIMEOUT_MS=15000
TXLINE_MAX_RESPONSE_BYTES=10000000
TXLINE_MAX_SSE_EVENTS=10
