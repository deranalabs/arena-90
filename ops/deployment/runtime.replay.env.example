ARENA90_RUNTIME_MODE=REPLAY
ARENA90_AUTOSTART=true
ARENA90_MANIFEST_FILE=/opt/arena90/current/fixtures/recorded-manifest.json
ARENA90_REPLAY_RECORDING_FILE=/opt/arena90/current/fixtures/recorded-checkpoints.json
ARENA90_HTTP_HOST=127.0.0.1
ARENA90_HTTP_PORT=3100
ARENA90_PERSISTENCE_DIR=/var/lib/arena90/persistence

ZEROCLAW_BIN=/usr/local/bin/zeroclaw
ZEROCLAW_CONFIG_DIR=/etc/arena90/zeroclaw
ARENA90_AGENT_TIMEOUT_MS=30000

ARENA90_REPLAY_SMOKE_TIMEOUT_MS=900000
ARENA90_HTTP_SMOKE_TIMEOUT_MS=900000
ARENA90_HTTP_SMOKE_MODE=PRODUCT_ACCEPTANCE
